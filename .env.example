# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# THIS FILE IS AN EXAMPLE ONLY. DO NOT ENTER REAL SECRETS HERE.
#
# Instructions:
# 1. Copy this file to .env: `cp .env.example .env`
# 2. Fill in the real values in the .env file.
# 3. Ensure .env is never committed to git (it should be in .gitignore).
# =============================================================================

# --- Database (PostgreSQL) ---
# Connection details for the main application database.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=otwarty_parlament
POSTGRES_USER=postgres_user_placeholder
POSTGRES_PASSWORD=postgres_password_placeholder

# --- AI Integration (Google Gemini) ---
# API Key for the Gemini model used in analysis scripts.
# Get one here: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Frontend Configuration (Vite) ---
# Public URLs and keys for the frontend application.
# API URL must point to your backend service (or localhost during dev).
VITE_API_URL=http://localhost:8000
VITE_POSTGREST_URL=http://localhost:8000
VITE_API_ANON_KEY=your_public_anon_key_placeholder

# --- Analytics (Umami) ---
# Website ID for tracking analytics (optional for local dev).
VITE_UMAMI_ID=your_umami_website_id_placeholder
