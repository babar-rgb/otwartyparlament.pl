#!/bin/bash

# Kolory dla lepszego UX
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}>>> Uruchamianie interfejsu otwartyparlament.pl (Truth Layer)...${NC}"

# Pobieramy ścieżkę do katalogu głównego projektu
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$PROJECT_DIR"

# Startujemy backend w tle
echo -e "${BLUE}>>> Uruchamianie Backend API (FastAPI) na porcie 8002...${NC}"
./.venv/bin/python3 -m uvicorn backend.main:app --port 8002 --reload &
BACKEND_PID=$!

# Trap do zabijania procesów po wciśnięciu Ctrl+C
trap 'echo -e "\n${BLUE}>>> Zamykanie serwerów...${NC}"; kill $BACKEND_PID; exit' SIGINT SIGTERM

# Próbujemy uruchomić serwer frontendu na pierwszym wolnym porcie od 8000
PORT=8000
while lsof -Pi :$PORT -sTCP:LISTEN -t >/dev/null ; do
    PORT=$((PORT+1))
done

echo -e "${GREEN}>>> Frontend startuje pod adresem: http://localhost:$PORT${NC}"
echo -e "${BLUE}>>> Naciśnij Ctrl+C, aby zakończyć oba serwery.${NC}"

# Uruchamiamy serwer frontendu bezpośrednio z folderu frontend
(cd frontend && python3 -m http.server $PORT)
