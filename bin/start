#!/bin/bash
# bin/start — Truth Layer: uruchamia frontend i backend równolegle.
# Użycie: ./bin/start
# Zatrzymanie: Ctrl+C (zabija oba procesy)

# --- Kolory ---
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# --- Katalog główny projektu ---
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$PROJECT_DIR"

echo ""
echo -e "${BLUE}╔══════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║   otwartyparlament.pl — Truth Layer      ║${NC}"
echo -e "${BLUE}╚══════════════════════════════════════════╝${NC}"
echo ""

# --- Porty ---
FRONTEND_PORT=8000
BACKEND_PORT=8002

# Frontend: znajdź wolny port
while lsof -Pi :$FRONTEND_PORT -sTCP:LISTEN -t >/dev/null 2>&1; do
    FRONTEND_PORT=$((FRONTEND_PORT + 1))
done

# Backend: jeśli port zajęty — zabij stary proces
if lsof -Pi :$BACKEND_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
    echo -e "${YELLOW}>>> Port $BACKEND_PORT zajęty — zatrzymuję stary backend...${NC}"
    lsof -ti :$BACKEND_PORT | xargs kill -9 2>/dev/null
    sleep 1
fi

# --- Sprawdź czy .venv istnieje ---
if [ ! -d ".venv" ]; then
    echo -e "${RED}✗ Brak środowiska .venv. Uruchom: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt${NC}"
    exit 1
fi

# --- Funkcja sprzątania przy Ctrl+C ---
cleanup() {
    echo ""
    echo -e "${YELLOW}>>> Zatrzymywanie serwerów...${NC}"
    kill "$BACKEND_PID" "$FRONTEND_PID" 2>/dev/null
    wait "$BACKEND_PID" "$FRONTEND_PID" 2>/dev/null
    echo -e "${GREEN}>>> Zakończono. Dobranoc.${NC}"
    exit 0
}
trap cleanup SIGINT SIGTERM

# --- Start backendu FastAPI ---
echo -e "${YELLOW}>>> [1/2] Backend FastAPI...${NC}"
.venv/bin/python3 -m uvicorn backend.main:app \
    --host 0.0.0.0 \
    --port $BACKEND_PORT \
    --reload \
    --log-level warning &
BACKEND_PID=$!

# Krótka pauza — czekamy aż FastAPI wystartuje
sleep 1

# Sprawdź czy backend faktycznie działa
if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    echo -e "${RED}✗ Backend nie uruchomił się. Sprawdź logi powyżej.${NC}"
    exit 1
fi

echo -e "${GREEN}  ✓ API dostępne pod: http://localhost:${BACKEND_PORT}/api${NC}"
echo -e "${GREEN}  ✓ Docs:             http://localhost:${BACKEND_PORT}/docs${NC}"

# --- Start frontendu (statyczny HTTP) ---
echo -e "${YELLOW}>>> [2/2] Frontend HTTP...${NC}"
python3 -m http.server $FRONTEND_PORT \
    --directory "$PROJECT_DIR/frontend" \
    --bind 127.0.0.1 &
FRONTEND_PID=$!

sleep 0.5

echo -e "${GREEN}  ✓ Aplikacja:        http://localhost:${FRONTEND_PORT}${NC}"
echo ""
echo -e "${BLUE}  Naciśnij Ctrl+C, aby zatrzymać oba serwery.${NC}"
echo ""

# --- Czekaj na zakończenie ---
wait
