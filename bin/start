#!/bin/bash

# Resolve project root and cd into it to ensure relative paths work
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_ROOT"

# Function to kill child processes on exit
cleanup() {
  echo "🛑 Zatrzymuję procesy..."
  kill $(jobs -p) 2>/dev/null
}
trap cleanup EXIT

echo "🚀 Otwarty Parlament - Start Systemu"
echo "-----------------------------------"

# 1. Check PostgreSQL
if ! pg_isready -h localhost -p 5432 > /dev/null 2>&1; then
  echo "⚠️  PostgreSQL nie jest uruchomiony!"
  echo "👉 Uruchamiam PostgreSQL..."
  brew services start postgresql@17
  sleep 3
fi
echo "✅ PostgreSQL gotowy!"

# 2. Start Backend (FastAPI with Uvicorn)
echo "🐍 Startuję Backend (FastAPI)..."

# Determine Python interpreter
PYTHON_CMD="python3"
if [ -f ".venv/bin/python" ]; then
    PYTHON_CMD=".venv/bin/python"
    echo "✅ Używam wirtualnego środowiska: $PYTHON_CMD"
elif [ -f "venv/bin/python" ]; then
    PYTHON_CMD="venv/bin/python"
    echo "✅ Używam wirtualnego środowiska: $PYTHON_CMD"
fi

# Run backend
$PYTHON_CMD -m uvicorn backend.main:app --reload --port 8000 &
BACKEND_PID=$!
sleep 2

# Check if backend started
if ps -p $BACKEND_PID > /dev/null; then
  echo "✅ API działa na porcie 8000"
else
  echo "❌ Błąd startu API! Sprawdź logi."
  exit 1
fi

# 3. Start Frontend
echo "💻 Startuję stronę (Vite)..."
npm run dev

# Wait for all background processes
wait
