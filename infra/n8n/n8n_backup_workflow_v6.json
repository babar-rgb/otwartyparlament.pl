{
    "name": "Daily Database Backup (V6 - 7GB Ready)",
    "nodes": [
        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "hours",
                            "hours": 3
                        }
                    ]
                }
            },
            "id": "schedule",
            "name": "Every Day at 3AM",
            "type": "n8n-nodes-base.scheduleTrigger",
            "typeVersion": 1.1,
            "position": [
                380,
                300
            ]
        },
        {
            "parameters": {
                "command": "CONTAINER=$(docker ps --format '{{.Names}}' | grep -E 'db|postgres' | grep -v 'backup' | head -n1)\ndocker exec $CONTAINER pg_dumpall -U postgres --clean | gzip > /tmp/backup_full.sql.gz"
            },
            "id": "ssh-dump",
            "name": "SSH: Dump to File",
            "type": "n8n-nodes-base.ssh",
            "typeVersion": 1,
            "position": [
                600,
                300
            ],
            "credentials": {
                "sshPassword": {
                    "id": "ssh-vps",
                    "name": "VPS Root"
                }
            }
        },
        {
            "parameters": {
                "protocol": "sftp",
                "operation": "download",
                "path": "/tmp/backup_full.sql.gz",
                "binaryPropertyName": "data"
            },
            "id": "sftp-download",
            "name": "SFTP: Download Stream",
            "type": "n8n-nodes-base.ftp",
            "typeVersion": 1,
            "position": [
                820,
                300
            ],
            "credentials": {
                "sftp": {
                    "id": "ssh-vps",
                    "name": "VPS Root"
                }
            }
        },
        {
            "parameters": {
                "authentication": "oAuth2",
                "fileName": "={{ 'backup_parlament_FULL_' + $now.toFormat('yyyy-MM-dd') + '.sql.gz' }}",
                "binaryData": true,
                "binaryPropertyName": "data"
            },
            "id": "google-drive",
            "name": "Upload to Drive",
            "type": "n8n-nodes-base.googleDrive",
            "typeVersion": 3,
            "position": [
                1040,
                300
            ],
            "credentials": {
                "googleDriveOAuth2Api": {
                    "id": "google-drive",
                    "name": "Google Drive account"
                }
            }
        },
        {
            "parameters": {
                "command": "rm /tmp/backup_full.sql.gz"
            },
            "id": "ssh-cleanup",
            "name": "SSH: Cleanup",
            "type": "n8n-nodes-base.ssh",
            "typeVersion": 1,
            "position": [
                1260,
                300
            ],
            "credentials": {
                "sshPassword": {
                    "id": "ssh-vps",
                    "name": "VPS Root"
                }
            }
        }
    ],
    "connections": {
        "Every Day at 3AM": {
            "main": [
                [
                    {
                        "node": "SSH: Dump to File",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "SSH: Dump to File": {
            "main": [
                [
                    {
                        "node": "SFTP: Download Stream",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "SFTP: Download Stream": {
            "main": [
                [
                    {
                        "node": "Upload to Drive",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Upload to Drive": {
            "main": [
                [
                    {
                        "node": "SSH: Cleanup",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    }
}